generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth-only projection of the user. Profile data (username, displayName, avatar)
// lives in user-service. Credentials never leave this service.
model UserAuth {
  userId       String   @id @default(uuid()) @map("user_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  refreshTokens RefreshToken[]

  @@map("user_auth")
}

// Stateful refresh tokens. Logout revokes; Refresh validates.
// Access tokens remain stateless JWTs.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user UserAuth @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_token")
}

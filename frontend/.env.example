# API base URL for REST calls. In dev Vite proxies "/api" → api-gateway, so
# leaving it as "/api" works for both dev and prod (prod has nginx proxying
# /api/ to localhost:8080 inside the EC2 behind the ALB).
VITE_API_URL=/api

# WebSocket URL for ws-gateway. Set for dev (Vite serves the SPA from :5173
# so socket.io needs the absolute URL of ws-gateway). Leave unset in prod —
# socket.io falls back to window.location.origin so the same build works
# behind any ALB/reverse proxy without rebuilding.
VITE_WS_URL=http://localhost:8081

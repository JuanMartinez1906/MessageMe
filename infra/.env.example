# Local development environment variables.
# Copy to .env and tweak as needed. .env is gitignored.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=messageme
POSTGRES_PASSWORD=messageme

# One DATABASE_URL per service (use the DBs created by scripts/postgres-init.sql)
DATABASE_URL_AUTH=postgresql://messageme:messageme@localhost:5432/messageme_auth
DATABASE_URL_USER=postgresql://messageme:messageme@localhost:5432/messageme_user
DATABASE_URL_GROUP=postgresql://messageme:messageme@localhost:5432/messageme_group
DATABASE_URL_CHANNEL=postgresql://messageme:messageme@localhost:5432/messageme_channel
DATABASE_URL_DIRECT=postgresql://messageme:messageme@localhost:5432/messageme_direct
DATABASE_URL_FILE=postgresql://messageme:messageme@localhost:5432/messageme_file

# MongoDB
MONGO_URL=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB_MESSAGES=messageme_messages
MONGO_DB_DELIVERY=messageme_delivery

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (use 'localhost:9092' from host, 'kafka:29092' from other containers)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=messageme

# JWT
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Object storage (local dev uses MinIO or skipped until Fase 4)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=messageme-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
